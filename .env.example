# RAIQO Demo — Environment Variables
# Copy this file to .env and fill in your values
# For Netlify: add these in Site settings → Environment variables

# ── Firebase ─────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── EmailJS ───────────────────────────────────────────────────────
# Get these from https://www.emailjs.com (free account, 200 emails/month)
# 1. Create account → Add Gmail service → Create template
# 2. Template variables: {{to_email}} {{to_name}} {{subject}} {{message}} {{product_name}} {{market}} {{event_type}} {{timestamp}}
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Demo notification target (your Gmail address)
VITE_DEMO_EMAIL=your.email@gmail.com

# ── WhatsApp (CallMeBot) ──────────────────────────────────────────
# FREE — no Meta approval needed for personal numbers
# 1. Send "I allow callmebot to send me messages" to +34 644 60 49 16 on WhatsApp
# 2. You'll receive your personal API key back on WhatsApp
# 3. Use your phone number WITHOUT the + sign
VITE_DEMO_WA_PHONE=971501234567
VITE_DEMO_WA_APIKEY=your_callmebot_api_key
